{
  "name": "deloitte-standard",
  "description": "Deloitte consulting standard for horizontal swimlane flowcharts. Dark background, white borders, green systems, yellow documents.",
  "default": true,
  "colors": {
    "background": "#000000",
    "primary_lane": "#2A2A2A",
    "secondary_lane": "#333333",
    "lane_border": "#CCCCCC",
    "activity_fill": "#000000",
    "activity_stroke": "#FFFFFF",
    "activity_font": "#FFFFFF",
    "system_input_fill": "#D1EDA0",
    "system_input_stroke": "#00AA00",
    "system_input_font": "#000000",
    "document_output_fill": "#FFC000",
    "document_output_stroke": "#FFD700",
    "document_output_font": "#000000",
    "decision_fill": "#000000",
    "decision_stroke": "#FFFFFF",
    "decision_font": "#FFFFFF",
    "start_end_fill": "#000000",
    "start_end_stroke": "#FFFFFF",
    "start_end_font": "#FFFFFF",
    "edge_stroke": "#FFFFFF"
  },
  "shapes": {
    "swimlane": "shape=swimlane;startSize=80;horizontal=0;swimlaneLine=1;",
    "activity": "rounded=0;whiteSpace=wrap;strokeWidth=2;fontSize=16;",
    "system_input": "shape=document;whiteSpace=wrap;fontSize=12;fontStyle=1;size=0;",
    "document_output": "shape=document;whiteSpace=wrap;fontSize=12;fontStyle=1;",
    "decision": "rhombus;whiteSpace=wrap;strokeWidth=2;fontSize=16;",
    "start_end": "rounded=1;whiteSpace=wrap;strokeWidth=2;fontSize=16;",
    "edge": "edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;"
  },
  "layout": {
    "orientation": "horizontal",
    "activity_width": 180,
    "activity_height": 50,
    "decision_width": 120,
    "decision_height": 70,
    "system_input_width": 80,
    "system_input_height": 30,
    "document_output_width": 100,
    "document_output_height": 29,
    "lane_height": 90,
    "lane_width": 1570,
    "horizontal_gap": 200,
    "vertical_gap": 90,
    "edge_corridor": 80
  },
  "rules": {
    "activity_numbering": "sequential_01_02",
    "start_position": "top_left",
    "end_position": "top_right",
    "connection_direction": "left_in_right_out",
    "decision_exits": "two_exits_with_labels",
    "input_position": "top_left",
    "output_position": "bottom_right",
    "edge_routing": "orthogonal_no_crossing",
    "role_organization": "vertical_left"
  }
}
